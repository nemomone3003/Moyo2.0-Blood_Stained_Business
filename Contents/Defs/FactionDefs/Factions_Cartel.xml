<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	<!-- 카르텔 팩션베이스 -->
	<FactionDef ParentName="FactionBase" Name="MoyoFactionBase_Cartel" Abstract="True">
		<pawnSingular>Operator</pawnSingular>
		<pawnsPlural>Operator</pawnsPlural>
		<listOrderPriority>31</listOrderPriority>
		<settlementGenerationWeight>1</settlementGenerationWeight>
		<requiredCountAtGameStart>1</requiredCountAtGameStart>
		<maxConfigurableAtWorldCreation>1</maxConfigurableAtWorldCreation>
		<configurationListOrderPriority>61</configurationListOrderPriority>
		<canMakeRandomly>true</canMakeRandomly>
		<leaderTitle>Administrator</leaderTitle>
		<canSiege>true</canSiege>
		<canStageAttacks>true</canStageAttacks>
		<techLevel>Ultra</techLevel>
		<allowedArrivalTemperatureRange>-50~35</allowedArrivalTemperatureRange>
		<raidLootMaker>MoyoCartelRaidLootMaker</raidLootMaker>
		<allowedCultures>
			<li>Moyo2_CartelCulture</li>
		</allowedCultures>
		<disallowedMemes>
			<li MayRequire="Ludeon.RimWorld.Ideology">Nudism</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">Blindsight</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">AnimalPersonhood</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">Rancher</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">TreeConnection</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">Structure_Animist</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">Structure_TheistEmbodied</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">Structure_TheistAbstract</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">NaturePrimacy</li>
		</disallowedMemes>
		<xenotypeSet>
			<xenotypeChances>
				<Moyo2_Xenotype_Depthborn MayRequire="Ludeon.RimWorld.Biotech">0.75</Moyo2_Xenotype_Depthborn>
				<Moyo2_Xenotype_Chemskin MayRequire="Ludeon.RimWorld.Biotech">0.25</Moyo2_Xenotype_Chemskin>
			</xenotypeChances>
		</xenotypeSet>
		<structureMemeWeights>
			<Structure_Ideological MayRequire="Ludeon.RimWorld.Ideology">3</Structure_Ideological>
			<Structure_Archist MayRequire="Ludeon.RimWorld.Ideology">1</Structure_Archist>
		</structureMemeWeights>
		<backstoryFilters>
			<li>
				<categories>
					<li>Outlander</li>
				</categories>
				<commonality>0.95</commonality>
			</li>
			<li>
				<categories>
					<li>Offworld</li>
				</categories>
				<commonality>0.05</commonality>
			</li>
		</backstoryFilters>
		<apparelStuffFilter>
			<thingDefs>
				<li>Moyo2_Cloth_Depthweave</li>
				<li>Synthread</li>
			</thingDefs>
			<stuffCategoriesToAllow>
				<li>Metallic</li>
			</stuffCategoriesToAllow>
			<disallowedThingDefs>
				<li>Leather_Thrumbo</li>
				<li>Hyperweave</li>
			</disallowedThingDefs>
		</apparelStuffFilter>
		<caravanTraderKinds>
			<li>Moyo2_Caravan_Cartel</li>
		</caravanTraderKinds>
		<visitorTraderKinds>
			<li>Visitor_Outlander_Standard</li>
		</visitorTraderKinds>
		<baseTraderKinds>
			<li>Moyo2_Base_Cartel</li>
		</baseTraderKinds>
		<maxPawnCostPerTotalPointsCurve>
			<points>
				<li>(0, 100)</li>
				<li>(1000, 150)</li>
				<li>(2000, 190)</li>
				<li>(3500, 280)</li>
				<li>(5000, 1000000)</li>
			</points>
		</maxPawnCostPerTotalPointsCurve>
		<pawnGroupMakers>
			<!-- 고급, 소수정예 습격 중심, 래비 참조 -->
			<li>
				<!-- 잠수부 습격 -->
				<kindDef>Combat</kindDef>
				<commonality>50</commonality>
				<options>
					<Moyo2_NPCDiverRecon>25</Moyo2_NPCDiverRecon>
					<Moyo2_NPCDiverReconMelee>10</Moyo2_NPCDiverReconMelee>
				</options>
			</li>
			<li>
				<!--중장 잠수부 습격 -->
				<kindDef>Combat</kindDef>
				<commonality>35</commonality>
				<options>
					<Moyo2_NPCDiverRecon>5</Moyo2_NPCDiverRecon>
					<Moyo2_NPCDiverReconMelee>5</Moyo2_NPCDiverReconMelee>
					<Moyo2_NPCDiverInfantry>30</Moyo2_NPCDiverInfantry>
					<Moyo2_NPCDiverHeavyGunner>5</Moyo2_NPCDiverHeavyGunner>
					<Moyo2_NPCDiverCrusher>10</Moyo2_NPCDiverCrusher>
				</options>
			</li>
			<li>
				<!-- 일반 주둔지 -->
				<kindDef>Settlement</kindDef>
				<options>
					<Moyo2_NPCTechnician>25</Moyo2_NPCTechnician>
					<Moyo2_NPCEngineer>10</Moyo2_NPCEngineer>
					<Moyo2_NPCEngineerMelee>10</Moyo2_NPCEngineerMelee>
					<Moyo2_NPCMiddleCivil>20</Moyo2_NPCMiddleCivil>
					<Moyo2_NPCTopCivil>10</Moyo2_NPCTopCivil>
					<Moyo2_NPCFlooded>3</Moyo2_NPCFlooded>
					<Moyo2_NPCNegotiator>1</Moyo2_NPCNegotiator>
				</options>
			</li>
			<li>
				<!-- 무법자 주둔지 -->
				<kindDef>Settlement</kindDef>
				<options>
					<Moyo2_NPCOutlaw>30</Moyo2_NPCOutlaw>
					<Moyo2_NPCOutlawJunkie>5</Moyo2_NPCOutlawJunkie>
					<Moyo2_NPCOutlawBoss>5</Moyo2_NPCOutlawBoss>
					<Moyo2_NPCTopCivil>10</Moyo2_NPCTopCivil>
					<Moyo2_NPCFlooded>8</Moyo2_NPCFlooded>
				</options>
			</li>
			<li>
				<!-- 거지 방문 -->
				<kindDef>Peaceful</kindDef>
				<options>
					<Moyo2_NPCTopCivil>5</Moyo2_NPCTopCivil>
					<Moyo2_NPCFlooded>1</Moyo2_NPCFlooded>
				</options>
			</li>
			<li>
				<!-- 카르텔 보급 수송대, 말도 안되게 강하게 -->
				<kindDef>Trader</kindDef>
				<traders>
					<Moyo2_NPCOutlawBoss>1</Moyo2_NPCOutlawBoss>
				</traders>
				<carriers>
					<Muffalo>6</Muffalo>
					<Dromedary>5</Dromedary>
					<Alpaca>2</Alpaca>
					<Elephant>1</Elephant>
				</carriers>
				<guards>
					<Moyo2_NPCOutlaw>30</Moyo2_NPCOutlaw>
					<Moyo2_NPCOutlawJunkie>5</Moyo2_NPCOutlawJunkie>
				</guards>
			</li>
		</pawnGroupMakers>
	</FactionDef>
	<FactionDef ParentName="MoyoFactionBase_Cartel">
		<defName>Moyo2_CartelFaction</defName>
		<label>Cartel surface division</label>
		<description>This is the Ground Operations Division of the Cartel, one of the major factions of the Lighthouse. Leveraging abundant resources and advanced technology, the Cartel continues to expand its ventures across the surface, interacting with neighboring factions through a strictly business-oriented mindset. Whether you become their newest partner and client—or choose to plunder their wealth and technological assets—is entirely up to you. Just remember: they show no mercy to those who stand in their way.\n\nThe Cartel's primary enterprise is the distribution of surface-world goods into the Lighthouse. This activity directly violates the Lighthouse Elders' long-standing policy of isolationism and is strictly forbidden. Despite this, the Cartel's influence continues to grow. Armed with cutting-edge equipment and experimental products of the Lighthouse's megacorps, they openly advocate for the abolition of isolationist policies. In response, the Elders branded them the "Cartel" and placed bounties on every one of its members.</description>
		<factionNameMaker>NamerFactionOutlander</factionNameMaker>
		<settlementNameMaker>NamerSettlementOutlander</settlementNameMaker>
		<settlementTexturePath>Icon/Icon_L_B</settlementTexturePath>
		<factionIconPath>Icon/Icon_L_B</factionIconPath>
		<leaderTitle>Refugee Haven elder</leaderTitle>
		<colorSpectrum>
			<li>(79, 183, 181)</li>
		</colorSpectrum>
		<pawnGroupMakers>
			<li>
				<!-- 더미 -->
				<kindDef>Combat</kindDef>
				<commonality>0</commonality>
				<disallowedStrategies>
					<li>Siege</li>
				</disallowedStrategies>
				<options>
					<Moyo2_NPCSiren>1</Moyo2_NPCSiren>
					<Moyo2_NPCBottomCivil>1</Moyo2_NPCBottomCivil>
				</options>
			</li>
		</pawnGroupMakers>
	</FactionDef>
	<ThingSetMakerDef>
		<defName>MoyoCartelRaidLootMaker</defName>
		<root Class="ThingSetMaker_MarketValue">
			<fixedParams>
				<filter>
					<thingDefs>
						<li>Silver</li>
						<li>MedicineIndustrial</li>
						<li>Moyo2_BlueMedicine</li>
						<li>ComponentIndustrial</li>
						<li>MealSurvivalPack</li>
						<li>Neutroamine</li>
					</thingDefs>
				</filter>
			</fixedParams>
		</root>
	</ThingSetMakerDef>
</Defs>
