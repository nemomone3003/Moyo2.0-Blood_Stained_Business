	<!-- 엔지니어 마스크-->
	<ThingDef ParentName="Moyo2_ApparelCategory_LightHouseHead">
		<defName>Moyo2_EGMask</defName>
		<label>depth engineer rebreather</label>
		<description>This breathing apparatus is favored by engineers and workers at the lighthouses. It offers protection against toxic gases from factories at a reasonable price and can be used as an underwater breathing device when connected to an oxygen tank. Made from high-strength materials, it also provides some degree of protection against physical hazards.\n\nThe lifespan of the respirator in industrial areas is 30 minutes. Users are strongly advised to familiarize themselves with the proper use of the respirator filter.</description>
		<graphicData>
			<texPath>Apparel/ArmorIDR/EGmask1</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>CutoutComplex</shaderType>
			<drawSize>1.2</drawSize>
		</graphicData>
		<uiIconScale>1.2</uiIconScale>
		<!-- - -->
		<statBases>
			<WorkToMake>10000</WorkToMake>
			<MaxHitPoints>100</MaxHitPoints>
			<Flammability>0.6</Flammability>
			<Mass>0.4</Mass>
			<ArmorRating_Sharp>0.45</ArmorRating_Sharp>
			<ArmorRating_Blunt>0.3</ArmorRating_Blunt>
			<Insulation_Cold>1.5</Insulation_Cold>
			<EquipDelay>0.5</EquipDelay>
		</statBases>
		<equippedStatOffsets>
			<ToxicEnvironmentResistance>0.8</ToxicEnvironmentResistance>
			<VacuumResistance MayRequire="Ludeon.RimWorld.Odyssey">0.3</VacuumResistance>
		</equippedStatOffsets>
		<!-- - -->
		<apparel>
			<bodyPartGroups>
				<li>Mouth</li>
			</bodyPartGroups>
			<wornGraphicPath>Apparel/ArmorIDR/EGmask</wornGraphicPath>
			<useWornGraphicMask>true</useWornGraphicMask>
			<layers>
