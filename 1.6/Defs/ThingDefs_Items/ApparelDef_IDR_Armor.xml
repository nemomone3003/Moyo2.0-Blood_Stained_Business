<Defs>
	<!-- 등대 -->
	<!-- 엔지니어 하네스-->
	<ThingDef ParentName="Moyo2_ApparelCategory_LightHouse">
		<defName>Moyo2_EGHarness</defName>
		<label>depth engineer harness</label>
		<description>This protective gear is favored by technicians and workers at the lighthouse. For a reasonable price, it shields users from both scalding heat and dangerous situations, oil stains too. It also comes with lots of pockets for storage.\n\nIndustrial zone workers are strongly encouraged to have protective gear while working. Attempting self-harm for insurance claims not only results in voided insurance but also leads to prosecution.</description>
		<graphicData>
			<texPath>Apparel/ArmorIDR/EGharness1</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>CutoutComplex</shaderType>
			<drawSize>1.2</drawSize>
		</graphicData>
		<uiIconScale>1.2</uiIconScale>
		<!-- - -->
		<statBases>
			<WorkToMake>11000</WorkToMake>
			<MaxHitPoints>200</MaxHitPoints>
			<Mass>3</Mass>
			<Flammability>0.6</Flammability>
			<ArmorRating_Sharp>0.72</ArmorRating_Sharp>
			<ArmorRating_Blunt>0.32</ArmorRating_Blunt>
			<ArmorRating_Heat>0.6</ArmorRating_Heat>
			<Insulation_Cold>3.5</Insulation_Cold>
			<Insulation_Heat>15</Insulation_Heat>
			<EquipDelay>4</EquipDelay>
		</statBases>
		<!-- - -->
		<apparel>
			<bodyPartGroups>
				<li>Legs</li>
				<li>Feet</li>
			</bodyPartGroups>
			<wornGraphicPath>Apparel/ArmorIDR/EGharness</wornGraphicPath>
			<useWornGraphicMask>true</useWornGraphicMask>
			<layers>
				<li>Middle</li>
			</layers>
			<tags>
				<li>Moyo2_Engineer</li>
				<li>Moyo2_EngineerNoHead</li>
				<li>Moyo2_HideBodyGlow</li>
			</tags>
		</apparel>
		<!-- - -->
		<recipeMaker>
			<researchPrerequisite>Moyo2_Abysstech_Pneumatic</researchPrerequisite>
			<skillRequirements>
				<Crafting>5</Crafting>
			</skillRequirements>
			<unfinishedThingDef>UnfinishedTechArmor</unfinishedThingDef>
		</recipeMaker>
		<costList>
			<ComponentIndustrial>2</ComponentIndustrial>
			<Steel>45</Steel>
			<Moyo2_Cloth_Depthweave>80</Moyo2_Cloth_Depthweave>
		</costList>
		<!-- - -->
		<colorGenerator Class="ColorGenerator_Options">
			<options>
				<li>
					<weight>1</weight>
					<only>(41,43,67)</only>
				</li>
			</options>
		</colorGenerator>
	</ThingDef>
