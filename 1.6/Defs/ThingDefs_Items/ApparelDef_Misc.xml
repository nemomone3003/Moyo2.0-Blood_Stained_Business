<Defs>
	<!-- 아기옷 -->
	<ThingDef ParentName="Moyo2_ApparelCategory_LightHouse" Name="Moyo2_Childclothes" Abstract="True">
		<graphicData>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>1.5</drawSize>
		</graphicData>
		<uiIconScale>1.2</uiIconScale>
		<!-- - -->
		<statBases>
			<MaxHitPoints>100</MaxHitPoints>
			<WorkToMake>4000</WorkToMake>
			<Mass>0.4</Mass>
			<ArmorRating_Sharp>0.50</ArmorRating_Sharp>
			<ArmorRating_Blunt>0.35</ArmorRating_Blunt>
			<ArmorRating_Heat>0.60</ArmorRating_Heat>
			<Insulation_Cold>35</Insulation_Cold>
			<Insulation_Heat>22.5</Insulation_Heat>
			<EquipDelay>3</EquipDelay>
		</statBases>
		<equippedStatOffsets>
			<MoveSpeed>-0.1</MoveSpeed>
		</equippedStatOffsets>
		<!-- - -->
		<apparel>
			<canBeDesiredForIdeo>false</canBeDesiredForIdeo>
			<developmentalStageFilter>Child</developmentalStageFilter>		
			<bodyPartGroups>
				<li>Torso</li>
				<li>Neck</li>
				<li>Shoulders</li>
				<li>Arms</li>
				<li>Legs</li>
			</bodyPartGroups>
			<layers>
				<li>Shell</li>
				<li>OnSkin</li>
			</layers>
			<tags>
				<li>Moyo2_HideBodyGlow</li>
				<li>Moyo2_HideAntenna</li>
			</tags>
		</apparel>
		<!-- - -->
		<recipeMaker>
			<researchPrerequisite>Moyo2_Abysstech_Pneumatic</researchPrerequisite>
			<skillRequirements>
				<Crafting>4</Crafting>
			</skillRequirements>
			<unfinishedThingDef>UnfinishedHealthItemBionic</unfinishedThingDef>
		</recipeMaker>
		<costList>
			<ComponentIndustrial>1</ComponentIndustrial>
			<Moyo2_Cloth_Depthweave>120</Moyo2_Cloth_Depthweave>
		</costList>
	</ThingDef>
	<!--펭귄 -->
	<ThingDef ParentName="Moyo2_Childclothes">
		<defName>Moyo2_Childclothes_A</defName>
		<label>hooded black cloak</label>
		<description>A thick Depthweave cloak with an attached hood, primarily used by cartel agents operating in the shadows of the Lighthouse. It also has limited bulletproof capabilities.\n\nThe term "cartel" refers to large corporations that currently oppose the ruling order of the Lighthouse, the Council. The cartel's influence has grown to rival that of the Council, and while both sides understand that their conflict could lead to the lighthouse's downfall, they have agreed to cooperate—for now, at least on the surface.</description>
		<graphicData>
			<texPath>Apparel/Misc/MoyoChildSuit1</texPath>
		</graphicData>
		<!-- - -->
		<apparel>
			<renderNodeProperties>
				<!-- Cloak -->
				<li Class="Moyo2.PawnRenderNodeProperties_Gendered">
					<nodeClass>Moyo2.PawnRenderNode_ApparelCustomPath</nodeClass>
					<workerClass>PawnRenderNodeWorker_Apparel_Body</workerClass>
					<texPath>Apparel/Misc/MoyoChildSuit</texPath>
					<visibleFacing>
						<li>East</li>
						<li>North</li>
						<li>West</li>
						<li>South</li>
					</visibleFacing>
					<baseLayer>22</baseLayer>
					<gendered>true</gendered>
				</li>
				<!-- Hood -->
				<li Class="Moyo2.PawnRenderNodeProperties_Gendered">
					<nodeClass>Moyo2.PawnRenderNode_ApparelCustomPath</nodeClass>
					<workerClass>Moyo2.PawnRenderNodeWorker_Apparel_Head_Offset</workerClass>
					<texPath>Apparel/Misc/MoyoChildHood</texPath>
					<visibleFacing>
						<li>East</li>
						<li>North</li>
						<li>West</li>
						<li>South</li>
					</visibleFacing>
					<baseLayer>73</baseLayer>
				</li>
			</renderNodeProperties>
		</apparel>
	</ThingDef>
