<Defs>
	<!-- 등대 -->
	<!-- 유선형 잠수용 쉘-->
	<ThingDef ParentName="Moyo2_ApparelCategory_LightHouse">
		<defName>Moyo2_StreamlineDivingShell</defName>
		<label>streamlined diving shell</label>
		<description>Diving suit of the lighthouse that prioritizes agility. It provides significant protection without greatly sacrificing mobility. The suit is designed to reduce resistance on its surface, allowing for relatively easy movement underwater. This feature is meaningless on land.\n\nThe diving suit's abysssteel armor plates also make it excellent body armor. It started being used in combat by the Lighthouse's security forces, and this trend has spread throughout the entire Lighthouse.</description>
		<graphicData>
			<texPath>Apparel/ArmorLMR/SDShell1</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>CutoutComplex</shaderType>
			<drawSize>1.2</drawSize>
		</graphicData>
		<uiIconScale>1.2</uiIconScale>
		<!-- - -->
		<statBases>
			<WorkToMake>55000</WorkToMake>
			<MaxHitPoints>350</MaxHitPoints>
			<Mass>7</Mass>
			<Flammability>0.2</Flammability>
			<ArmorRating_Sharp>1.0</ArmorRating_Sharp>
			<ArmorRating_Blunt>0.55</ArmorRating_Blunt>
			<ArmorRating_Heat>0.55</ArmorRating_Heat>
			<Insulation_Cold>66</Insulation_Cold>
			<Insulation_Heat>14</Insulation_Heat>
			<EquipDelay>16</EquipDelay>
		</statBases>
		<equippedStatOffsets>
			<ToxicEnvironmentResistance>0.15</ToxicEnvironmentResistance>
			<Flammability>-0.5</Flammability>
			<MoveSpeed>-0.2</MoveSpeed>
			<SlaveSuppressionOffset MayRequire="Ludeon.RimWorld.Ideology">-0.3</SlaveSuppressionOffset>
			<VacuumResistance MayRequire="Ludeon.RimWorld.Odyssey">0.3</VacuumResistance>
		</equippedStatOffsets>
		<!-- - -->
		<apparel>
			<bodyPartGroups>
				<li>Torso</li>
				<li>Neck</li>
				<li>Shoulders</li>
				<li>Arms</li>
				<li>Hands</li>
				<li>Legs</li>
				<li>Feet</li>
			</bodyPartGroups>
			<wornGraphicPath>Apparel/ArmorLMR/SDShell</wornGraphicPath>
			<useWornGraphicMask>true</useWornGraphicMask>
			<drawData>
				<dataNorth>
					<layer>60</layer>
				</dataNorth>
			</drawData>
			<!--<renderSkipFlags>
				<li>Body</li>
			</renderSkipFlags>-->
			<layers>
				<li>Middle</li>
				<li>Shell</li>
			</layers>
			<tags>
				<li>Moyo2_DiverLight</li>
				<li>Moyo2_BigArmor</li>
				<li>Moyo2_HideBodyGlow</li>
				<li>Moyo2_HideTail</li>
			</tags>
		</apparel>
		<!-- - -->
		<recipeMaker>
			<researchPrerequisite>Moyo2_Abysstech_DivingShell</researchPrerequisite>
			<skillRequirements>
				<Crafting>6</Crafting>
			</skillRequirements>
			<unfinishedThingDef>UnfinishedTechArmor</unfinishedThingDef>
		</recipeMaker>
		<costList>
			<ComponentSpacer>3</ComponentSpacer>
			<Moyo2_Abyssteel>80</Moyo2_Abyssteel>
			<Moyo2_Cloth_Depthweave>50</Moyo2_Cloth_Depthweave>
		</costList>
		<!-- - -->
		<colorGenerator Class="ColorGenerator_Options">
			<options>
				<li>
					<weight>1</weight>
					<only>(41,43,67)</only>
				</li>
			</options>
		</colorGenerator>
	</ThingDef>
