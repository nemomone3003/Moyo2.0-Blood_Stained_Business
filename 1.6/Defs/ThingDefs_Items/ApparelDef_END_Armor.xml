			<EquipDelay>20</EquipDelay>
		</statBases>
		<equippedStatOffsets>
			<ToxicEnvironmentResistance>0.2</ToxicEnvironmentResistance>
			<Flammability>-0.7</Flammability>
			<MoveSpeed>-0.5</MoveSpeed>
