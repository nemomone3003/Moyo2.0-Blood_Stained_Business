		<description>Diving helmetof the lighthouse that prioritizes agility. It provides significant protection without greatly sacrificing mobility. The built-in oxygen respirator has been removed.\n\nOriginally designed purely for work purposes, the suit's design has evolved into a combat-capable diving suit as the Lighthouse becomes increasingly chaotic.</description>
		<graphicData>
			<texPath>Apparel/ArmorLMR/SDHelmet1</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>CutoutComplex</shaderType>
			<drawSize>1.2</drawSize>
		</graphicData>
		<uiIconScale>1.2</uiIconScale>
		<!-- - -->
		<statBases>
			<WorkToMake>15000</WorkToMake>
			<MaxHitPoints>250</MaxHitPoints>
			<Mass>3</Mass>
			<Flammability>0.2</Flammability>
			<ArmorRating_Sharp>1.0</ArmorRating_Sharp>
			<ArmorRating_Blunt>0.55</ArmorRating_Blunt>
			<ArmorRating_Heat>0.55</ArmorRating_Heat>
			<Insulation_Cold>5</Insulation_Cold>
			<EquipDelay>2</EquipDelay>
		</statBases>
		<equippedStatOffsets>
			<ToxicEnvironmentResistance>0.55</ToxicEnvironmentResistance>
			<SlaveSuppressionOffset MayRequire="Ludeon.RimWorld.Ideology">-0.1</SlaveSuppressionOffset>
			<VacuumResistance MayRequire="Ludeon.RimWorld.Odyssey">0.65</VacuumResistance>
		</equippedStatOffsets>
		<!-- - -->
		<apparel>
			<bodyPartGroups>
				<li>FullHead</li>
			</bodyPartGroups>
			<wornGraphicPath>Apparel/ArmorLMR/SDHelmet</wornGraphicPath>
			<!--<renderSkipFlags>
				<li>Head</li>
			</renderSkipFlags>-->
			<layers>
				<li>Overhead</li>
			</layers>
			<tags>
				<li>Moyo2_WraithLight</li>
				<li>Moyo2_BigHelmet</li>
				<li>Moyo2_HideFaceGlow</li>
				<li>Moyo2_HideAntenna</li>
				<li>Moyo2_HideHair</li>
			</tags>
		</apparel>
		<!-- - -->
		<recipeMaker>
			<researchPrerequisite>Moyo2_Abysstech_DivingShell</researchPrerequisite>
			<skillRequirements>
				<Crafting>6</Crafting>
			</skillRequirements>
			<unfinishedThingDef>UnfinishedTechArmor</unfinishedThingDef>
		</recipeMaker>
		<costList>
			<ComponentSpacer>1</ComponentSpacer>
			<Moyo2_Abyssteel>25</Moyo2_Abyssteel>
			<Moyo2_Cloth_Depthweave>10</Moyo2_Cloth_Depthweave>
		</costList>
	</ThingDef>
	<!-- 심층 잠수용 쉘-->
	<ThingDef ParentName="Moyo2_ApparelCategory_LightHouse">
