<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	<!--기본형 바디슈트-->
	<ThingDef ParentName="Moyo2_ApparelCategory_LightHouse">
		<defName>Moyo2_BasicSuit</defName>
		<label>standard bodysuit</label>
		<description>This bodysuit represents the lighthouse's attire culture. Made with depthweave, it's both sturdy and elastic. It's worn by people of all ages and genders, with various products being marketed for funtions such as ease of wear and body-shaping.</description>
		<graphicData>
			<texPath>Apparel/Bodysuit/BasicSuit1</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>1.2</drawSize>
		</graphicData>
		<uiIconScale>1.2</uiIconScale>
		<!-- - -->
		<statBases>
			<MaxHitPoints>100</MaxHitPoints>
			<WorkToMake>8000</WorkToMake>
			<Mass>0.5</Mass>
			<ArmorRating_Sharp>0.16</ArmorRating_Sharp>
			<ArmorRating_Blunt>0.06</ArmorRating_Blunt>
			<ArmorRating_Heat>0.40</ArmorRating_Heat>
			<Insulation_Cold>21.5</Insulation_Cold>
			<Insulation_Heat>12</Insulation_Heat>
			<EquipDelay>4</EquipDelay>
		</statBases>
		<!-- - -->
		<apparel>
			<bodyPartGroups>
				<li>Torso</li>
				<li>Neck</li>
				<li>Shoulders</li>
				<li>Arms</li>
				<li>Hands</li>
				<li>Legs</li>
				<li>Feet</li>
			</bodyPartGroups>
			<wornGraphicPath>Apparel/Bodysuit/BasicSuit</wornGraphicPath>
			<layers>
				<li>OnSkin</li>
			</layers>
			<tags>
				<li>Moyo2_SuitBasic</li>
				<li>Moyo2_HideBodyGlow</li>
			</tags>
		</apparel>
		<!-- - -->
		<recipeMaker>
			<researchPrerequisite>Moyo2_Abysstech_Pneumatic</researchPrerequisite>
			<skillRequirements>
				<Crafting>4</Crafting>
			</skillRequirements>
			<unfinishedThingDef>UnfinishedHealthItemBionic</unfinishedThingDef>
			<recipeUsers Inherit="False">
				<li>TableMachining</li>
				<li>Moyo2_FabricationBench</li>
			</recipeUsers>
		</recipeMaker>
		<costList>
			<Moyo2_Cloth_Depthweave>80</Moyo2_Cloth_Depthweave>
		</costList>
	</ThingDef>
	<!-- - -->
	
	<!--개선형 바디슈트-->
	<ThingDef ParentName="Moyo2_ApparelCategory_LightHouse">
		<defName>Moyo2_AdvancedSuit</defName>
		<label>advanced bodysuit</label>
		<description>A bodysuit that focuses on user protection with its thick fabric and temperature regulation features. It's rarely used as casual wear and is predominantly utilized by military personnel, police officers, or high-risk laborers who could afford this.</description>
		<graphicData>
			<texPath>Apparel/Bodysuit/CompositeSuit1</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>1.2</drawSize>
		</graphicData>
		<uiIconScale>1.2</uiIconScale>
		<!-- - -->
		<statBases>
			<MaxHitPoints>150</MaxHitPoints>
			<WorkToMake>12000</WorkToMake>
			<Mass>0.5</Mass>
			<ArmorRating_Sharp>0.50</ArmorRating_Sharp>
			<ArmorRating_Blunt>0.35</ArmorRating_Blunt>
			<ArmorRating_Heat>0.60</ArmorRating_Heat>
			<Insulation_Cold>35</Insulation_Cold>
			<Insulation_Heat>22.5</Insulation_Heat>
			<EquipDelay>2</EquipDelay>
		</statBases>
		<equippedStatOffsets>
			<VacuumResistance MayRequire="Ludeon.RimWorld.Odyssey">0.15</VacuumResistance>
		</equippedStatOffsets>
		<!-- - -->
		<apparel>
			<bodyPartGroups>
				<li>Torso</li>
				<li>Neck</li>
				<li>Shoulders</li>
				<li>Arms</li>
				<li>Hands</li>
				<li>Legs</li>
				<li>Feet</li>
			</bodyPartGroups>
			<wornGraphicPath>Apparel/Bodysuit/CompositeSuit</wornGraphicPath>
			<layers>
				<li>OnSkin</li>
			</layers>
			<tags>
				<li>Moyo2_SuitAdvanced</li>
				<li>RoyalTier5</li>
				<li>Moyo2_HideBodyGlow</li>
			</tags>
		</apparel>
		<!-- - -->
		<recipeMaker>
			<researchPrerequisite>Moyo2_Abysstech_LaminarTheory</researchPrerequisite>
			<skillRequirements>
				<Crafting>6</Crafting>
			</skillRequirements>
			<unfinishedThingDef>UnfinishedTechArmor</unfinishedThingDef>
		</recipeMaker>
		<costList>
			<ComponentIndustrial>3</ComponentIndustrial>
			<Moyo2_Cloth_Depthweave>90</Moyo2_Cloth_Depthweave>
			<DevilstrandCloth>15</DevilstrandCloth>
		</costList>
	</ThingDef>
