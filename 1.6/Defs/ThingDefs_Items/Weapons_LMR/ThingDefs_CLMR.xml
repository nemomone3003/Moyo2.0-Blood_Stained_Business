	<ThingDef ParentName="Moyo2_CLMRRifle">
		<defName>Moyo2_CLMRRifle</defName>
		<label>laminar carbine</label>
		<description>A signature firearm design of the cartel, this compact rifle fires small rounds with incredible velocity, granting extraordinary armor piercing capability.</description>
